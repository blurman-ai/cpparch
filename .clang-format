---
# База — LLVM coding standards.
# Одно осознанное отступление — Allman braces (см. docs/code_style.md §«Почему Allman»).
# Любые другие отличия от LLVM-default — это баг, исправляйте PR-ом.
Language: Cpp
BasedOnStyle: LLVM
Standard: c++20

# Наша девиация от LLVM-default Attach.
BreakBeforeBraces: Allman

# Шире чем LLVM-default 80 — современные IDE-ы это терпят легко.
ColumnLimit: 120

# Группировка include-блоков (стандартная → сторонние → archcheck → остальные).
IncludeBlocks: Regroup
IncludeCategories:
  - Regex: '^<[A-Za-z0-9_/.-]+\.h>'
    Priority: 1
  - Regex: '^<[A-Za-z0-9_/.-]+>'
    Priority: 2
  - Regex: '^"archcheck/'
    Priority: 3
  - Regex: '.*'
    Priority: 4
